@page
@model RankingModel
@{
    ViewData["Title"] = "Ranking";
}

<h1>Ranking Top 5</h1>

@if (Model.Ranking.Count == 0)
{
    <p>Ranking ainda vazio. <a href="/Play">Sê o primeiro a jogar!</a></p>
}
else
{
    <table class="stats-table">
        <thead>
            <tr>
                <th>Posição</th>
                <th>Utilizador</th>
                <th>Score</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Ranking.Count; i++)
            {
                <tr>
                    <td><strong>@(i + 1)</strong></td>
                    <td>@Model.Ranking[i].Username</td>
                    <td class="positive">@Model.Ranking[i].Score</td>
                </tr>
            }
        </tbody>
    </table>
}

<p><a href="/" class="btn btn-secondary">Voltar ao Início</a></p>
